# =============================================================
#  kor-welfare-hub — 외부 API 키 모음
# =============================================================
# 사용법
#   1) 파일명을 .env.local 로 복사 (이 파일 자체는 그대로 두세요)
#   2) 각 키를 발급받아 = 우측에 붙여넣기
#   3) npm run dev 재시작 또는 npm run sync:<name>
#
# 모든 키는 비어있어도 동작합니다 (해당 소스만 비활성화).
# 한국 공공 API는 전부 무료이며 회원가입만 하면 즉시 발급됩니다.
# =============================================================


# ──────────────────────────────────────────────
# 1. 복지로 (한국사회보장정보원_사회보장급여 사업목록)
# ──────────────────────────────────────────────
# 신청: https://www.data.go.kr/data/15098570/openapi.do
#   → [활용신청] (자동승인, 즉시)
# 키 위치: 마이페이지 → 데이터활용 → "일반 인증키(Decoding)" 복사
# 호출 예상 건수: 5,000~9,000
BOKJIRO_API_KEY=


# ──────────────────────────────────────────────
# 2. 온통청년 (청년정책 통합검색)
# ──────────────────────────────────────────────
# 신청: https://www.youthcenter.go.kr/opi/openApiList.do
#   → 회원가입 → 좌측 [Open API 신청] → 사용목적 입력 → 즉시 발급
# 키 위치: 마이페이지 → Open API 인증키 (영문 18자리)
# 호출 예상 건수: 5,000~10,000
# 주의: data.go.kr가 아닌 youthcenter.go.kr 자체 발급 시스템
YOUTHCENTER_API_KEY=


# ──────────────────────────────────────────────
# 3. 정부24 (행정안전부_정부24 안내서비스)
# ──────────────────────────────────────────────
# 신청: https://www.data.go.kr/data/15090787/openapi.do  (생애주기별 안내)
#   또는: https://www.data.go.kr/data/15077048/openapi.do (서비스 안내)
#   → [활용신청] (일부 자동, 일부 1~3일 심사)
# 키 위치: 마이페이지 → 일반 인증키(Decoding)
# 호출 예상 건수: 1,000~3,000
GOV24_API_KEY=


# ──────────────────────────────────────────────
# 4. 워크넷 (고용노동부_채용정보 / 직업훈련)
# ──────────────────────────────────────────────
# 신청: https://www.work24.go.kr/cm/openApi/main.do
#   → 회원가입 → [인증키 발급신청] → 즉시 발급
# 키 위치: 마이페이지 → 인증키
# 호출 예상 건수: 500~2,000 (정책·훈련·채용 중 정책 위주 수집)
WORKNET_API_KEY=


# ──────────────────────────────────────────────
# 5. (선택) 서울 열린데이터광장
# ──────────────────────────────────────────────
# 신청: https://data.seoul.go.kr/together/guide/useGuide.do
#   → 회원가입 → [인증키 신청]
# 호출 예상 건수: 광역 데이터 수백~수천
SEOUL_OPEN_API_KEY=


# ──────────────────────────────────────────────
# 6. (선택) 경기데이터드림
# ──────────────────────────────────────────────
# 신청: https://data.gg.go.kr/portal/mainPage.do → 회원가입 → API 신청
GYEONGGI_API_KEY=
